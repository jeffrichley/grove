}

#packs-required-message {
  height: auto;
  margin-bottom: 1;
  padding: 0;
}

#packs-optional-label {
  height: auto;
  margin-top: 2;
  margin-bottom: 1;
  padding: 0;
}

#packs-optional-list {
  height: auto;
  max-height: 12;
  margin-top: 0;
  padding: 0 1;
  border: solid $primary 50%;
}

#recommended-packs-content #action-radios {
  margin-top: 2;
  padding-top: 1;
  border-top: solid $primary 25%;
  width: 100%;
}

